# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database → Connection String
# Use "Transaction pooler" URL for DATABASE_URL (port 6543)
# Use "Direct connection" URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-vercel-app.vercel.app"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@yourdomain.com"

# ─── QR Token Signing ────────────────────────────────────────────────────────
# Same value as NEXTAUTH_SECRET or a separate secret
QR_SECRET="your-qr-secret-here"

# ─── S3-compatible Storage (obrigatório para upload de templates no Vercel) ───
# Supabase Storage: Dashboard → Storage → S3 Connection
#   Endpoint: https://<project-ref>.supabase.co/storage/v1/s3
#   Region: us-east-1 (ou o da sua região)
#   Access Key / Secret Key: Dashboard → Project Settings → Data API → S3 keys
#   Bucket: crie um bucket público chamado "crachasys" (ou o nome que quiser)
#   Public URL: https://<project-ref>.supabase.co/storage/v1/object/public/crachasys
#
# AWS S3:
#   Endpoint: https://s3.<region>.amazonaws.com (ou deixe em branco)
#   Bucket: seu-bucket
#   Public URL: https://<bucket>.s3.<region>.amazonaws.com
STORAGE_ENDPOINT="https://<project-ref>.supabase.co/storage/v1/s3"
STORAGE_ACCESS_KEY="your-s3-access-key"
STORAGE_SECRET_KEY="your-s3-secret-key"
STORAGE_BUCKET="crachasys"
STORAGE_REGION="us-east-1"
NEXT_PUBLIC_STORAGE_PUBLIC_URL="https://<project-ref>.supabase.co/storage/v1/object/public/crachasys"
