# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database → Connection String
# Use "Transaction pooler" URL for DATABASE_URL (port 6543)
# Use "Direct connection" URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-vercel-app.vercel.app"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@yourdomain.com"

# ─── QR Token Signing ────────────────────────────────────────────────────────
# Same value as NEXTAUTH_SECRET or a separate secret
QR_SECRET="your-qr-secret-here"
